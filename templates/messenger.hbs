<div>
    {{#if (isAtLeastOneUserToBeShown)}}
        <div class="users">
            <ul>
                {{> "modules/lame-messenger/templates/sub-templates/users.hbs"}}
            </ul>
        </div>
    {{else}}
        <div class="users no-users-to-show">
            <p> {{ localize 'LAME.NoUsersToShow' }} </p>
            <p> {{ localize 'LAME.NoUsersToShowExplanation' }} </p>
        </div>
    {{/if}}

	<div class="chat-elements">
<textarea class="history" placeholder="{{ localize 'LAME.History.Hint' }}" disabled>
{{> "modules/lame-messenger/templates/sub-templates/history.hbs"}}
</textarea>

		<textarea class="message" name="message" placeholder="{{ localize 'LAME.WhisperHint' }}" rows="3"></textarea>

		<button class="send">
            <!-- > not type="submit" - that triggers "submit the web page as a form". use type="button"
                  https://discord.com/channels/170995199584108546/722559135371231352/1238597859876540566 -->
			<i class="far fa-paper-plane"></i> {{ localize 'LAME.Send' }}
		</button>
	</div>

</div>
